# GlobalFork — environment variables
#
# Copy to `.env.local` for local development, or set in Vercel project settings
# for production. NEXT_PUBLIC_* vars are exposed to the browser; everything else
# is server-only.
#
# Defaults for every var live in src/lib/site-config.ts so a missing var never
# breaks the build — but a real launch needs the items below filled.

# --- Public site identity ---------------------------------------------------

# Production domain. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://globalforkfh.com

# --- Public contact inboxes -------------------------------------------------

NEXT_PUBLIC_EMAIL_GENERAL=hello@globalfork.example
NEXT_PUBLIC_EMAIL_VENDORS=vendors@globalfork.example
NEXT_PUBLIC_EMAIL_CAREERS=careers@globalfork.example
NEXT_PUBLIC_EMAIL_BOOKINGS=bookings@globalfork.example
NEXT_PUBLIC_EMAIL_PRIVACY=privacy@globalfork.example
NEXT_PUBLIC_EMAIL_ACCESSIBILITY=accessibility@globalfork.example

# --- Business (Restaurant JSON-LD) ------------------------------------------

# Optional. Leave blank to omit from structured data.
NEXT_PUBLIC_TELEPHONE=

# --- Social -----------------------------------------------------------------

# e.g. "globalfork" (no @, no URL) — leave blank to link to instagram.com
NEXT_PUBLIC_INSTAGRAM=

# Behold (behol.so) feed ID — powers the live Instagram grid in the Follow
# section. Connect IG + create a feed at behold.so, then paste the Feed ID.
# Leave blank to keep the brand-gradient placeholder grid.
NEXT_PUBLIC_BEHOLD_FEED_ID=

# --- Legal ------------------------------------------------------------------

NEXT_PUBLIC_LEGAL_ENTITY=Global Fork (legal entity TBC)
NEXT_PUBLIC_LEGAL_JURISDICTION=State of California
NEXT_PUBLIC_RETENTION_MONTHS=18
# YYYY-MM-DD shown as "Effective" on legal pages.
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=2026-04-27

# --- Server-only (form handler — wire up when DECISIONS_NEEDED §3 is answered) ---

# RESEND_API_KEY=
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# SENTRY_DSN=
